APP_NAME=ANPR System
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:////app/data/anpr.db
REDIS_URL=redis://redis:6379/0
SNAPSHOT_DIR=/app/snapshots
MODEL_PATH=/app/models/license_plate_yolov8.pt
YOLO_DEVICE=auto
FRAME_SKIP=3
MAX_QUEUE_SIZE=8
DUPLICATE_TIMEOUT_SECONDS=300
OCR_CONFIDENCE_THRESHOLD=0.65
DETECTION_CONFIDENCE_THRESHOLD=0.35
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
