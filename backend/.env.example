APP_NAME=ANPR System
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:////app/data/anpr.db
REDIS_URL=redis://redis:6379/0
SNAPSHOT_DIR=/app/snapshots
MODEL_PATH=/app/models/license_plate_yolov8.pt
YOLO_DEVICE=auto
FRAME_SKIP=3
MAX_QUEUE_SIZE=8
DUPLICATE_TIMEOUT_SECONDS=300
OCR_CONFIDENCE_THRESHOLD=0.65
DETECTION_CONFIDENCE_THRESHOLD=0.35
PADDLE_USE_GPU=false
PLATE_MIN_ASPECT_RATIO=1.8
PLATE_MAX_ASPECT_RATIO=7.5
PLATE_CROP_PADDING_X=0.35
PLATE_CROP_PADDING_Y=0.35
FRAME_IGNORE_TOP_RATIO=0.12
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
